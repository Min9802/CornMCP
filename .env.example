# ─── Corn Hub Environment Configuration ──────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── General ─────────────────────────────────────────────
NODE_ENV=development

# ─── Auth / Secrets (S1) ─────────────────────────
AUTH_JWT_SECRET=changeme
# Master key for encrypting provider_accounts.api_key and future system_settings.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to AUTH_JWT_SECRET when unset.
SYSTEM_SETTINGS_MASTER_KEY=

# ─── Embedding Provider (Voyage / OpenAI / LM Studio / Ollama) ──
# Priority for each field below: corn-api system_settings DB row > env var > null.
# Once the admin sets a value via the dashboard System Settings UI, it overrides
# the env entry. The env entries below remain as cold-start fallbacks (useful
# when corn-api is briefly unreachable or for fresh clones before first login).
#
# Endpoint must be OpenAI-compatible (POST /embeddings with {input, model}).
# Examples:
#   Voyage:    OPENAI_API_BASE=https://api.voyageai.com/v1   MEM9_EMBEDDING_MODEL=voyage-code-3
#   OpenAI:    OPENAI_API_BASE=https://api.openai.com/v1     MEM9_EMBEDDING_MODEL=text-embedding-3-small
#   LM Studio: OPENAI_API_BASE=http://<host>:1234/v1         MEM9_EMBEDDING_MODEL=text-embedding-bge-m3
#   Ollama:    OPENAI_API_BASE=http://<host>:11434/v1        MEM9_EMBEDDING_MODEL=bge-m3
OPENAI_API_BASE=https://api.voyageai.com/v1
OPENAI_API_KEY=pa-...
MEM9_EMBEDDING_MODEL=voyage-code-3
MEM9_EMBEDDING_DIMS=1024
# Comma-separated fallback models used when the primary is rate-limited (429).
# ENV-ONLY (no DB override): rotation is a transient 429-recovery knob, not a
# steady-state config, so it doesn't need admin UI propagation latency.
# CRITICAL: every fallback model MUST output the same dim as MEM9_EMBEDDING_DIMS
# AND must be available on the same OPENAI_API_BASE — otherwise a rotation will
# produce vectors that mismatch existing Qdrant collections, or fail auth on
# the local endpoint (e.g. listing voyage-3-* when base points to LM Studio).
# Leave empty for no rotation (primary will retry with backoff then fail).
MEM9_FALLBACK_MODELS=
# ─── Gemini (optional, for LLM gateway) ──────────────────
GEMINI_API_KEY=

# ─── MCP API Keys (one per agent) ────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CORN_API_KEY_DEFAULT=

# ─── Dashboard ───────────────────────────────────────────
DASHBOARD_PORT=3000

# ─── Service URLs ────────────────────────────────────────
QDRANT_URL=http://localhost:6333
DATABASE_PATH=./data/corn.db

# ─── Session lifecycle ───────────────────────────────────
# Active sessions with no activity for this many minutes are auto-flipped to
# 'abandoned' (status). Activity = POST /api/sessions, PATCH /api/sessions/:id,
# POST /api/sessions/:id/heartbeat, or a quality_report tied to the session.
SESSION_AUTO_CLOSE_MINUTES=60
# How often the sweep runs (milliseconds, min 30000).
SESSION_CHECK_INTERVAL_MS=300000
