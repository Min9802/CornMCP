# Corn Hub — Docker Environment
# Copy to .env and fill in actual values
AUTH_JWT_SECRET=changeme

# ── Database driver ──────────────────────────
# Toggle between SQLite (legacy) and MongoDB (post-migration).
#   sqlite → uses sql.js + DATABASE_PATH (in-memory + file persist)
#   mongo  → uses Mongoose + MONGODB_URI (host MongoDB 7+/8 service)
# Stays `sqlite` until Phase 3 refactor finishes (~295 call sites). Flip to
# `mongo` at Phase 5 cutover; remove the toggle entirely at Phase 6 cleanup.
DATABASE_DRIVER=sqlite

# ── MongoDB (post-migration) ─────────────────
# Service runs on the HOST (NOT in compose). Compose sets host.docker.internal
# via `extra_hosts: "host.docker.internal:host-gateway"` so corn-api inside the
# container can reach the host's mongod.
#   - From container : mongodb://cornhub:***@host.docker.internal:27017/cornhub?authSource=admin&replicaSet=rs0
#   - From host (dev): mongodb://cornhub:***@127.0.0.1:27017/cornhub?authSource=admin&replicaSet=rs0
# Replica set is REQUIRED for transactions (single-node rs0 is fine for dev/staging).
MONGODB_URI=mongodb://cornhub:changeme@host.docker.internal:27017/cornhub?authSource=admin&replicaSet=rs0

# ── SQLite (legacy, kept until Phase 6 cleanup) ──
# Only consulted when DATABASE_DRIVER=sqlite. Path is mounted from
# `infra/api-data/corn.db` via the docker-compose volume.
DATABASE_PATH=/app/data/corn.db

# ── System Settings master key (S1) ──────────
# Used to derive AES-256 key for encrypting provider_accounts.api_key and
# future system_settings.value (is_secret=1). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to AUTH_JWT_SECRET if unset (so existing deploys keep working),
# but production should set this explicitly so the JWT secret can rotate
# independently of the encryption key.
SYSTEM_SETTINGS_MASTER_KEY=
# ── Ports ────────────────────────────────────
API_PORT=6100
MCP_PORT=8317
WEB_PORT=3000
# ── URLs ─────────────────────────────────────
# API URL as seen by browser (for Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:6100
NEXT_PUBLIC_MCP_URL=http://localhost:8317
# Allowed CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# ── Qdrant Vector Store ──────────────────────
# Required by corn-mcp memory + knowledge tools.
# Inside docker-compose this resolves to http://qdrant:6333; for local dev
# point at the qdrant container's published port.
QDRANT_URL=http://localhost:6333

# ── Voyage AI / OpenAI (for mem9 embeddings) ───
OPENAI_API_BASE=https://api.voyageai.com/v1
OPENAI_API_KEY=pa-...

# ── Gemini (alternative embeddings) ──────────
GEMINI_API_KEY=

# ── Embedding Model ──────────────────────────
MEM9_EMBEDDING_MODEL=voyage-code-3
MEM9_EMBEDDING_DIMS=1024

# ── Build metadata (auto-populated by CI) ────
COMMIT_SHA=dev
BUILD_DATE=

MAIL_MAILER=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# ── Google OAuth ─────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SESSION_AUTO_CLOSE_MINUTES=60
SESSION_CHECK_INTERVAL_MS=30000